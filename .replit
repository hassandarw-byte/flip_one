entrypoint = "README.md"
modules = ["nodejs-22"]

[nix]
channel = "stable-24_05"

[deployment]
deploymentTarget = "cloudrun"
build = ["sh", "-c", "npm run expo:static:build && npm run server:build"]
run = ["npm", "run", "server:prod"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[env]
PORT = "5000"

[agent]
stack = "EXPO"
integrations = ["javascript_database:1.0.0", "revenuecat:1.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start App"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Frontend"

[[workflows.workflow]]
name = "Start App"
author = "agent"
mode = "parallel"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Backend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Frontend"

[[workflows.workflow]]
name = "Start Backend"
author = "agent"
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run server:dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Start Frontend"
author = "agent"
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run expo:dev"

[workflows.workflow.metadata]
outputType = "console"

[userenv]

[userenv.shared]
EXPO_PUBLIC_REVENUECAT_TEST_API_KEY = "test_xjlyAogmQaPywPYJDvquzLJEOUd"
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY = "appl_agfKNovZovhQXHpWfkUgCJlpaOW"
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY = "goog_gqjjgJgxuJRLIogdnecGLwWCuQw"
REVENUECAT_PROJECT_ID = "projd49934eb"
REVENUECAT_TEST_STORE_APP_ID = "appc4fe514ad3"
REVENUECAT_APPLE_APP_STORE_APP_ID = "app493f385d59"
REVENUECAT_GOOGLE_PLAY_STORE_APP_ID = "app38ce0ca9ec"
